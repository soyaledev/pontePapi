# Supabase - Proyecto PontePapi
# URL base de la app (links de verificación de correo). Local: http://localhost:3000 | Producción: https://pontepapi.com
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=https://ufbbdujcanvdcsjdwrmo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Mercado Pago Split (OAuth)
NEXT_PUBLIC_MP_CLIENT_ID=tu-app-id-marketplace
MP_CLIENT_SECRET=tu-client-secret
# Producción: https://barbert.vercel.app/dueno/mercadopago/callback | Local: http://localhost:3000/dueno/mercadopago/callback
NEXT_PUBLIC_MP_REDIRECT_URI=https://barbert.vercel.app/dueno/mercadopago/callback
MP_REDIRECT_URI=
# Webhook: secret para verificar firma x-signature (opcional; si no está, no se valida)
MERCADOPAGO_WEBHOOK_SECRET=

# Backend (para llamar create-preference)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Ultramail (comprobante de reserva y verificación de correo)
ULTRAMAIL_API_KEY=
ULTRAMAIL_TEMPLATE_ID=
ULTRAMAIL_VERIFICATION_TEMPLATE_ID=
# Opcional: URL base de Ultramail si usás otra instancia
# ULTRAMAIL_URL=https://ultramailad.vercel.app/api/send
